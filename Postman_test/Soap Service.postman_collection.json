          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = xml2Json(pm.response.text());\r",
                  "\r",
                  "const result =\r",
                  "    json[\"s:Envelope\"][\"s:Body\"][\"GetSupplierByIdResponse\"][\"GetSupplierByIdResult\"]\r",
                  ";\r",
                  "\r",
                  "pm.test(\"Supplier details are correct\", function () {\r",
                  "    pm.expect(result[\"d4p1:Name\"]).to.eql(\"ABC Supplies\");\r",
                  "    pm.expect(result[\"d4p1:SupplierId\"]).to.eql(\"1\");\r",
                  "});\r",
                  "pm.test(\"Response contains required fields\", function () {\r",
                  "    pm.expect(result).to.have.property(\"d4p1:Name\");\r",
                  "    pm.expect(result).to.have.property(\"d4p1:SupplierId\");\r",
                  "\r",
                  "    pm.expect(result[\"d4p1:Name\"]).to.be.a(\"string\");\r",
                  "    pm.expect(result[\"d4p1:Name\"]).to.exist;\r",
                  "    pm.expect(result[\"d4p1:Name\"]).to.not.be.empty;\r",
                  "    pm.expect(Number(result[\"d4p1:SupplierId\"])).to.be.a(\"number\");\r",
                  "    pm.expect(result[\"d4p1:SupplierId\"]).to.exist;\r",
                  "    pm.expect(result[\"d4p1:SupplierId\"]).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "//is weaker because it only checks that those strings appear somewhere in the response.\r",
                  "/*pm.test(\"Response contains Name and SupplierId tags\", function () {\r",
                  "    const body = pm.response.text();\r",
                  "    pm.expect(body).to.include(\"Name\");\r",

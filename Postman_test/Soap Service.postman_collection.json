          "name": "GetSupplierById(1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = xml2Json(pm.response.text());\r",
                  "\r",
                  "const result =\r",
                  "    json[\"s:Envelope\"][\"s:Body\"][\"GetSupplierByIdResponse\"][\"GetSupplierByIdResult\"];\r",
                  "\r",
                  "pm.test(\"Supplier details are correct\", function () {\r",
                  "    pm.expect(result[\"d4p1:Name\"]).to.eql(\"ABC Supplies\");\r",
